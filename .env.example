# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Docker Compose loads `.env` automatically for variable substitution in docker-compose.yml.
# Do not commit real keys.
#
# Compose project name is set in docker-compose.yml (`name: game-surf-llm`).
# Hugging Face / PyTorch downloads go to `Tools/LLM/.docker-cache/` (see docker-compose.yml), not only into Docker’s VM disk.

# --- Integrated inference server (scripts/llm_integrated_server.py) ---
HOST=0.0.0.0
PORT=8000
MODEL_PATH=exports/training_test_export/gguf_gguf/llama-3.2-3b-instruct.Q4_K_M.gguf
LORE_DIR=research/world_lore
INDEX_STORAGE=datasets/indexes/world_lore
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHAT_HISTORY_TOKEN_LIMIT=1500

# Supabase (optional; leave key empty to skip client / use ENABLE_SUPABASE=false)
# Native WSL runs should use the API_URL from `supabase status -o env`.
# Docker containers may still use http://host.docker.internal:54321.
SUPABASE_URL=http://127.0.0.1:16433
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_SUPABASE=true

# Optional: scripts/validate_oracle.py (defaults to http://localhost:8005/chat)
# CHAT_URL=http://localhost:8005/chat
