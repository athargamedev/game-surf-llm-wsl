{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "filesystem": {
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\GithubRepos\\Game_Surf"
      ],
      "enabled": true,
      "timeout": 30000,
      "type": "local"
    },
    "sequentialthinking": {
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 50000,
      "type": "local"
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server"],
      "args": ["--context", "codex", "--project-from-cwd"],
      "enabled": true
    },
    "supabase": {
      "enabled": true,
      "type": "remote",
      "url": "http://172.29.235.102:16434/api/mcp"
    },
    "unity-mcp": {
      "command": [
        "cmd",
        "/c",
        "--mcp",
        "C:\\Users\\andre_wjgj23f\\.unity\\relay\\relay_win.exe"
      ],
        "enabled": true,
        "timeout": 50000,
        "type": "local"
    }
  },
  "model": "opencode/big-pickle",
  "plugin": [
    "oh-my-openagent",
    "opencode-antigravity-auth@1.6.0",
    "opencode-openai-codex-auth"
  ],
  "provider": {
    "google": {
      "models": {
        "antigravity-gemini-3-flash": {
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 3 Flash (Antigravity)"
        },
        "antigravity-gemini-3-pro-high": {
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 3 Pro High (Antigravity)"
        },
        "antigravity-gemini-3-pro-low": {
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 3 Pro Low (Antigravity)"
        }
      },
      "name": "Google"
    },
    "lmstudio": {
      "models": {
        "qwen3-4b-qwen3.6-plus-reasoning-distilled": {
          "name": "qwen3.6"
        }
      },
      "name": "LM Studio (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    },
    "openai": {
      "models": {
        "gpt-5.1-codex-max": {
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "GPT 5.1 Codex Max (OAuth)",
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "medium": {
